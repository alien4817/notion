# No token is required for the first-stage probe.
# Set DEBUG_DSMS=1 for more verbose network and parsing logs.
DEBUG_DSMS=0

# Required only when writing new_records / updated_records to Notion.
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Optional. Use commas or newlines for multiple URLs.
# HTTPS on dsms.fda.gov.tw can close TLS connections from GitHub Actions,
# so the monitor defaults to HTTP and also falls back from HTTPS to HTTP.
FDA_DSMS_URL=http://dsms.fda.gov.tw/LatestNews.aspx,http://dsms.fda.gov.tw/DrugList.aspx?s=3
